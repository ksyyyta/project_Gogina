"""
Из предложенного текстового файла (text18-4.txt) вывести на экран его содержимое,
количество символов, принадлежащих к группе букв. Сформировать новый файл, в
который поместить текст в стихотворной форме предварительно заменив символы верхнего
регистра на нижний.

"""
with open('text18-4.txt', 'r', encoding='utf-8') as file:
    text = file.read()
    print("Исходный текст: ", text)
    letters = 0
    for symbol in text:
        if symbol.isalpha():
            letters += 1
    print(f" Количество букв: {letters}")

with open('text18-4_lower.txt', 'w', encoding='utf-8') as new_file:
    new_file.write(text.lower())

print("Файл 'text18-4_lower.txt' с текстом в нижнем регистре")

